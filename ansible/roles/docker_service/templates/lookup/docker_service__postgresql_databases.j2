---
{% for svc in docker_service__combined_services | d([]) %}
{%   if svc.state | d('present') not in ['absent', 'ignore'] %}
{%     if svc.postgresql is defined %}
{%       set pg = svc.postgresql %}
- name: '{{ pg.database }}'
  owner: '{{ pg.database }}'
{%     endif %}
{%   endif %}
{% endfor %}

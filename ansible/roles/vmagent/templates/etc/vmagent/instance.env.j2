# {{ ansible_managed }}
#
# vmagent environment file for instance: {{ instance.name }}
# Consumed via systemd EnvironmentFile=; ARGS is expanded into the
# vmagent command line by the vmagent@.service unit.

{% set flag_defaults = vmagent__instance_default_flags | d({}) %}
{% set flag_overrides = instance.flags | d({}) %}
{% set instance_flags = flag_defaults | combine(flag_overrides) %}
{% set args = [] %}
{# Hardwired flags built from the instance definition #}
{% set _ = args.append('-promscrape.config=' ~ vmagent__config_dir ~ '/' ~ instance.name ~ '.yml') %}
{% set _ = args.append('-remoteWrite.tmpDataPath=' ~ vmagent__home ~ '/' ~ instance.name) %}
{# remote_write_urls become repeated -remoteWrite.url flags #}
{% for url in instance.remote_write_urls | d([]) %}
{%   set _ = args.append('-remoteWrite.url=' ~ url) %}
{% endfor %}
{# Optional shared bearer token applied to every -remoteWrite.url #}
{% if instance.bearer_token | d(False) | bool %}
{%   set _ = args.append('-remoteWrite.bearerTokenFile=' ~ vmagent__home ~ '/' ~ instance.name ~ '/bearer_token') %}
{% endif %}
{# Generic key/value flags from merged defaults + per-instance flags #}
{% for key, value in instance_flags | dictsort %}
{%   if value is sameas true %}
{%     set _ = args.append('-' ~ key) %}
{%   elif value is sameas false %}
{# Skip false booleans entirely #}
{%   elif value is iterable and value is not string and value is not mapping %}
{%     for v in value %}
{%       set _ = args.append('-' ~ key ~ '=' ~ v | string) %}
{%     endfor %}
{%   else %}
{%     set _ = args.append('-' ~ key ~ '=' ~ value | string) %}
{%   endif %}
{% endfor %}
ARGS="{{ args | join(' ') }}"

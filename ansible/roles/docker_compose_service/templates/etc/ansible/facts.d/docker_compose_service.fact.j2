from __future__ import print_function
from json import dumps, loads
import subprocess
import os


def cmd_exists(cmd):
    return any(
        os.access(os.path.join(path, cmd), os.X_OK)
        for path in os.environ["PATH"].split(os.pathsep)
    )


output = {
    'installed': cmd_exists('docker'),
    'projects': {},
    'firewall': {
{% for svc in docker_compose_service__combined_services | d([]) %}
{%   if svc.state | d('present') not in ['absent', 'ignore']
        and svc.published_ports | d([]) | selectattr('allow', 'defined') | list | length > 0 %}
        '{{ svc.name }}': {{ svc.published_ports
                              | selectattr('allow', 'defined')
                              | list | to_json }},
{%   endif %}
{% endfor %}
    },
}

if output['installed']:
    try:
        ls_output = subprocess.check_output(
            ['docker', 'compose', 'ls', '--format', 'json'],
            stderr=subprocess.DEVNULL
        ).decode('utf-8').strip()

        for project in loads(ls_output):
            output['projects'][project.get('Name', '')] = {
                'status': project.get('Status', ''),
                'config_files': project.get('ConfigFiles', ''),
            }
    except Exception:
        pass

print(dumps(output, sort_keys=True, indent=4))
